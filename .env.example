# MongoDB (required at runtime). Atlas: SRV string; allow Vercel/serverless IPs in Atlas Network Access.
# MONGODB_URI="mongodb+srv://USER:PASSWORD@cluster.mongodb.net/DATABASE?retryWrites=true&w=majority"

# JWT signing (required). Use a long random string in production (e.g. openssl rand -base64 32).
# JWT_SECRET=
# Optional token lifetime (default 7d)
# JWT_EXPIRES_IN=7d

# Optional: comma-separated allowed browser origins. If unset, localhost + https://*.vercel.app are allowed
# (any Vercel-hosted frontend can call this API; add custom domains below if you use them).
# Add custom domains here, e.g. https://www.yoursite.com,https://dashboard.yoursite.com
# Use * to allow all origins (not recommended with credentials)
# CORS_ORIGINS=
